# PostgreSQL (Контент-Завод 2.0)
DATABASE_URL=postgresql://user:password@localhost:5432/content_factory

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_KEY=./secrets/google-sa-key.json
SPREADSHEET_ID=1abc...xyz
# Эталонная таблица для копирования новым клиентам (опционально; иначе передавать --template-id в create-client-table)
TEMPLATE_SPREADSHEET_ID=
# Google Email админа — всегда выдаётся доступ к новым таблицам клиентов (writer)
ADMIN_GOOGLE_EMAIL=

# OpenRouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_GROUNDING_MODEL=perplexity/sonar
OPENROUTER_TEXT_MODEL=deepseek/deepseek-chat
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
# Транскрибация голоса/видео в онбординге (модель с input_audio)
OPENROUTER_TRANSCRIPTION_MODEL=google/gemini-2.5-flash

# Яндекс Wordstat (через Директ)
YANDEX_OAUTH_TOKEN=y0_...
YANDEX_WORDSTAT_CLIENT_ID=abc123

# Beget S3 (эндпоинт из панели Beget: Объектное хранилище → Настройки)
S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ba368d4f4852-content-factory-images

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHANNEL_ID=@nursery_channel
TELEGRAM_NOTIFY_CHAT_ID=123456789
# Бот для онбординга (создать через BotFather, опционально)
ONBOARDING_BOT_TOKEN=

# Redis — обязателен для работы (очереди BullMQ, сессии онбординга, состояние публикаций). Без запущенного Redis приложение не стартует. Для Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Расписание и retry
POLL_INTERVAL_MS=60000
MAX_ARTICLES_PER_DAY=10
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=2000
# Таймаут запросов к OpenRouter, мс (защита от зависания; по умолчанию 120000)
OPENROUTER_TIMEOUT_MS=120000
