{
  "name": "content-factory",
  "version": "1.0.0",
  "description": "Контент-Завод: генерация статей из ключевых слов, публикация в Telegram/Дзен",
  "main": "dist/index.js",
  "scripts": {
    "build": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && npx esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --packages=external",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "hide-rows": "ts-node src/scripts/hideRows.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.650.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "openai": "^4.73.0",
    "sharp": "^0.33.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
